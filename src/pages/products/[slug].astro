---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ImageCarousel from '../../components/ImageCarousel';
import ProductTabs from '../../components/ProductTabs';
import ContactForm from '../../components/ContactForm';
import ShareButton from '../../components/ShareButton';
import VideoEmbed from '../../components/VideoEmbed.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const {
  title, tagline, description, logo, heroImage, websiteUrl,
  brandColor, brochureType, brochureFile,
  features, specs, pricing, gallery, videoUrl,
  formspreeId, category, tags,
} = product.data;

const { Content } = await render(product);

// Icon map for feature icons
const iconPaths: Record<string, string> = {
  sparkles: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z',
  layers: 'M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0l4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0l-5.571 3-5.571-3',
  plug: 'M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25',
  shield: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
  users: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z',
  chart: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z',
};
const defaultIcon = 'M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z';
---

<BaseLayout
  title={`${title} — Product Flyer`}
  description={description}
  ogImage={heroImage ?? logo}
>
  <!-- ─────────────────────────────── MARKDOWN MODE ─────────────────────────────── -->
  {brochureType === 'markdown' && (
    <>
      {/* ── Hero ── */}
      <section
        class="relative overflow-hidden py-24 sm:py-32"
        style={`background: linear-gradient(135deg, ${brandColor}12 0%, transparent 60%), linear-gradient(to bottom, #fff7ed, #f8fafc)`}
      >
        {/* Glow blob */}
        <div
          class="absolute inset-0 pointer-events-none"
          style={`background: radial-gradient(ellipse 60% 50% at 50% 0%, ${brandColor}18, transparent)`}
        ></div>

        <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          {/* Back link */}
          <a
            href="/"
            class="inline-flex items-center gap-1.5 text-slate-500 hover:text-slate-900 text-sm mb-10 transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
            All products
          </a>

          <div class="flex flex-col lg:flex-row items-start lg:items-center gap-10">
            {/* Left: info */}
            <div class="flex-1">
              <div class="flex items-center gap-4 mb-6">
                <div
                  class="w-16 h-16 rounded-2xl flex items-center justify-center border"
                  style={`background: ${brandColor}22; border-color: ${brandColor}44; box-shadow: 0 0 30px ${brandColor}33`}
                >
                  <img src={logo} alt={`${title} logo`} class="w-10 h-10 object-contain"
                    onerror={`this.style.display='none';this.nextElementSibling.style.display='block'`} />
                  <span class="hidden text-2xl font-bold text-white">{title.charAt(0)}</span>
                </div>
                <div>
                  <span class="text-sm font-medium text-slate-500 uppercase tracking-wider">{category}</span>
                  <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900">{title}</h1>
                </div>
              </div>

              <p class="text-xl text-slate-700 font-medium mb-3">{tagline}</p>
              <p class="text-slate-600 leading-relaxed max-w-2xl mb-8">{description}</p>

              <div class="flex flex-wrap items-center gap-3">
                <a
                  href={websiteUrl}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 text-white font-semibold px-5 py-3 rounded-xl transition hover:opacity-90"
                  style={`background: ${brandColor}`}
                >
                  Visit Website
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                  </svg>
                </a>
                <a
                  href="#contact"
                  class="inline-flex items-center gap-2 text-slate-700 font-semibold px-5 py-3 rounded-xl border border-slate-300 hover:bg-slate-100 hover:text-slate-900 transition"
                >
                  Get in touch
                </a>
                <ShareButton
                  client:load
                  title={`${title} — Product Flyer`}
                  text={tagline}
                  brandColor={brandColor}
                />
              </div>

              {tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-6">
                  {tags.map(tag => (
                    <span class="text-xs text-slate-500 bg-slate-100 border border-slate-200 px-2.5 py-1 rounded-full">#{tag}</span>
                  ))}
                </div>
              )}
            </div>

            {/* Right: hero image */}
            {heroImage && (
              <div class="w-full lg:w-[480px] shrink-0">
                <img
                  src={heroImage}
                  alt={`${title} hero`}
                  class="w-full rounded-2xl border border-slate-700 shadow-2xl"
                  onerror="this.parentElement.style.display='none'"
                />
              </div>
            )}
          </div>
        </div>
      </section>

      {/* ── Features ── */}
      {features && features.length > 0 && (
        <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
          <div class="text-center mb-12" data-aos="fade-up">
            <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-3">Everything you need</h2>
            <p class="text-slate-600 text-lg">Powerful features designed to help your team move faster.</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {features.map((f, i) => (
              <div
                class="bg-white border border-slate-200 rounded-2xl p-6 hover:border-orange-200 shadow-sm transition-colors"
                data-aos="fade-up"
                data-aos-delay={i * 60}
              >
                <div
                  class="w-10 h-10 rounded-xl flex items-center justify-center mb-4"
                  style={`background: ${brandColor}22`}
                >
                  <svg class="w-5 h-5" style={`color: ${brandColor}`} fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[f.icon ?? ''] ?? defaultIcon} />
                  </svg>
                </div>
                <h3 class="text-slate-900 font-semibold text-lg mb-2">{f.title}</h3>
                <p class="text-slate-600 text-sm leading-relaxed">{f.description}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      {/* ── Gallery ── */}
      {gallery && gallery.length > 0 && (
        <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16" data-aos="fade-up">
          <h2 class="text-3xl font-bold text-slate-900 mb-8 text-center">Screenshots</h2>
          <ImageCarousel client:visible images={gallery} />
        </section>
      )}

      {/* ── Video ── */}
      {videoUrl && (
        <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16" data-aos="fade-up">
          <h2 class="text-3xl font-bold text-slate-900 mb-8 text-center">See it in action</h2>
          <VideoEmbed videoUrl={videoUrl} title={`${title} demo video`} />
        </section>
      )}

      {/* ── Specs & Pricing ── */}
      {((specs && specs.length > 0) || (pricing && pricing.length > 0)) && (
        <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16" data-aos="fade-up">
          <h2 class="text-3xl font-bold text-slate-900 mb-8 text-center">Details & Pricing</h2>
          <ProductTabs
            client:visible
            specs={specs}
            pricing={pricing}
            brandColor={brandColor}
          />
        </section>
      )}

      {/* ── Markdown body ── */}
      <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12" data-aos="fade-up">
          <div class="prose prose-slate max-w-none">
          <Content />
        </div>
      </section>

      {/* ── Contact form ── */}
      <section id="contact" class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-20" data-aos="fade-up">
          <div class="bg-white border border-slate-200 rounded-3xl p-8 sm:p-12 shadow-sm">
          <div class="text-center mb-10">
              <h2 class="text-3xl font-bold text-slate-900 mb-3">Get in touch</h2>
              <p class="text-slate-600">
              Interested in {title}? Send us a message and we'll get back to you within 24 hours.
            </p>
          </div>
          <ContactForm
            client:visible
            formspreeId={formspreeId}
            productName={title}
            brandColor={brandColor}
          />
        </div>
      </section>

      {/* ── Bottom CTA ── */}
      <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
        <div
          class="flex flex-col sm:flex-row items-center justify-between gap-4 border-t border-slate-200 pt-8"
        >
          <a
            href="/"
            class="inline-flex items-center gap-2 text-slate-500 hover:text-slate-900 text-sm transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
            Back to all products
          </a>
          <a
            href={websiteUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 text-white font-semibold px-5 py-2.5 rounded-xl transition hover:opacity-90 text-sm"
            style={`background: ${brandColor}`}
          >
            Try {title} →
          </a>
        </div>
      </section>
    </>
  )}

  <!-- ─────────────────────────────── HTML MODE ─────────────────────────────── -->
  {brochureType === 'html' && (
    <>
      {/* Thin chrome */}
      <div class="bg-white border-b border-slate-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <a
              href="/"
              class="inline-flex items-center gap-1.5 text-slate-500 hover:text-slate-900 text-sm transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
              </svg>
              Products
            </a>
            <span class="text-slate-300">/</span>
            <span class="text-slate-900 text-sm font-semibold">{title}</span>
          </div>
          <ShareButton
            client:load
            title={`${title} — Product Flyer`}
            text={tagline}
            brandColor={brandColor}
          />
        </div>
      </div>
      {/* Full-bleed iframe */}
      {brochureFile ? (
        <iframe
          src={brochureFile}
          title={`${title} interactive flyer`}
          class="html-embed"
          sandbox="allow-scripts allow-same-origin allow-popups allow-popups-to-escape-sandbox"
        ></iframe>
      ) : (
        <div class="flex items-center justify-center h-[60vh] text-slate-500">
          <p>brochureFile not set for this product.</p>
        </div>
      )}
    </>
  )}

  <!-- ─────────────────────────────── PDF MODE ─────────────────────────────── -->
  {brochureType === 'pdf' && (
    <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      {/* Header */}
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
        <div>
          <a href="/" class="inline-flex items-center gap-1.5 text-slate-400 hover:text-white text-sm transition-colors mb-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
            All products
          </a>
          <h1 class="text-2xl font-bold text-slate-900">{title}</h1>
          <p class="text-slate-600 text-sm">{tagline}</p>
        </div>
        <div class="flex items-center gap-3">
          <ShareButton
            client:load
            title={`${title} — Product Brochure`}
            text={tagline}
            brandColor={brandColor}
          />
          {brochureFile && (
            <a
              href={brochureFile}
              download
              class="inline-flex items-center gap-2 text-white font-semibold px-4 py-2.5 rounded-xl text-sm transition hover:opacity-90"
              style={`background: ${brandColor}`}
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
              </svg>
              Download PDF
            </a>
          )}
        </div>
      </div>
      {/* PDF embed */}
      {brochureFile ? (
        <iframe
          src={`${brochureFile}#toolbar=0&navpanes=0`}
          title={`${title} brochure`}
          class="pdf-embed"
        ></iframe>
      ) : (
          <div class="flex items-center justify-center h-[60vh] text-slate-500 border border-slate-200 rounded-2xl">
          <p>brochureFile not set for this product.</p>
        </div>
      )}
    </section>
  )}
</BaseLayout>

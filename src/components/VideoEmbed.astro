---
interface Props {
  videoUrl: string;
  title?: string;
}

const { videoUrl, title = 'Product video' } = Astro.props;

// Convert plain YouTube watch URLs to embed URLs
const embedUrl = videoUrl
  .replace('watch?v=', 'embed/')
  .replace('youtu.be/', 'www.youtube.com/embed/');
---

<div class="relative aspect-video rounded-2xl overflow-hidden border border-slate-700 bg-slate-900">
  <iframe
    src={embedUrl}
    title={title}
    class="w-full h-full"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
    loading="lazy"
  ></iframe>
</div>

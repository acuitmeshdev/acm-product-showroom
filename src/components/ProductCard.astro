---
import type { CollectionEntry } from 'astro:content';

interface Props {
  product: CollectionEntry<'products'>;
  index?: number;
}

const { product, index = 0 } = Astro.props;
const { title, tagline, logo, brandColor, category, tags, brochureType } = product.data;

const typeLabel: Record<string, string> = {
  markdown: 'Interactive',
  html: 'Flyer',
  pdf: 'PDF Brochure',
};
const typeBadge: Record<string, string> = {
  markdown: 'bg-orange-100 text-orange-700 border-orange-200',
  html: 'bg-amber-100 text-amber-700 border-amber-200',
  pdf: 'bg-rose-100 text-rose-700 border-rose-200',
};
---

<a
  href={`/products/${product.id}`}
  class="group relative flex flex-col bg-white border border-slate-200 rounded-2xl overflow-hidden hover:border-orange-300 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-slate-200/70"
  data-aos="fade-up"
  data-aos-delay={index * 80}
>
  <!-- Brand color accent bar -->
  <div class="h-1 w-full" style={`background: linear-gradient(90deg, ${brandColor}, ${brandColor}88)`}></div>

  <div class="flex flex-col flex-1 p-6">
    <!-- Logo + type badge -->
    <div class="flex items-start justify-between mb-5">
      <div
        class="w-14 h-14 rounded-xl flex items-center justify-center bg-orange-50 border border-orange-100 overflow-hidden"
        style={`box-shadow: 0 0 20px ${brandColor}33`}
      >
        <img src={logo} alt={`${title} logo`} class="w-10 h-10 object-contain" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
        <span class="hidden items-center justify-center w-full h-full text-xl font-bold text-white">
          {title.charAt(0)}
        </span>
      </div>
      <span class={`text-xs font-semibold px-2.5 py-1 rounded-full border ${typeBadge[brochureType]}`}>
        {typeLabel[brochureType]}
      </span>
    </div>

    <!-- Category -->
    <span class="text-xs font-medium text-slate-500 uppercase tracking-wider mb-2">{category}</span>

    <!-- Title & tagline -->
    <h2 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-orange-600 transition-colors">{title}</h2>
    <p class="text-slate-600 text-sm leading-relaxed flex-1">{tagline}</p>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-4">
        {tags.slice(0, 3).map(tag => (
          <span class="text-xs text-slate-500 bg-slate-100 px-2 py-0.5 rounded-md">#{tag}</span>
        ))}
      </div>
    )}

    <!-- CTA -->
    <div class="mt-5 flex items-center gap-2 text-sm font-semibold text-orange-500 group-hover:text-orange-600 transition-colors">
      View Flyer
      <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
    </div>
  </div>
</a>
